// ============================================================
// NEXUS TAKEOFF MODULE — PRISMA SCHEMA ADDITION
// APPEND these 4 models to your existing prisma/schema.prisma
// Do NOT replace your existing schema — append only.
// ============================================================

// ─── Enums (add these to your existing enums section) ────────

enum PlanSheetStatus {
  uploading
  processing
  ready
  error
}

enum TakeoffStatus {
  draft
  in_progress
  qa_review
  complete
}

enum TakeoffItemStatus {
  ai_detected
  pending_review
  approved
  flagged
  overridden
}

enum ShapeType {
  polygon
  polyline
  rectangle
  count
  point
}

enum MeasurementUnit {
  SF
  SY
  LF
  EA
  CY
  CF
  TON
  LB
  GAL
  LS
}

// ─── Models ──────────────────────────────────────────────────

model PlanSet {
  id          String      @id @default(uuid())
  project_id  String
  name        String
  version     String      @default("1.0")
  uploaded_by String
  sheet_count Int         @default(0)
  status      PlanSheetStatus @default(processing)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  sheets      PlanSheet[]
  takeoffs    Takeoff[]

  @@index([project_id])
  @@map("plan_sets")
}

model PlanSheet {
  id              String          @id @default(uuid())
  plan_set_id     String
  sheet_number    String          // e.g. "A-101"
  sheet_title     String
  discipline      String          @default("Architectural")
  storage_path    String          // Supabase Storage path
  thumbnail_path  String?
  width_px        Int             @default(0)
  height_px       Int             @default(0)
  scale_ratio     Float?          // pixels per foot
  scale_source    String?         // "manual" | "auto_detected"
  page_number     Int             @default(0)
  status          PlanSheetStatus @default(processing)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  plan_set        PlanSet         @relation(fields: [plan_set_id], references: [id], onDelete: Cascade)
  takeoff_items   TakeoffItem[]

  @@index([plan_set_id])
  @@map("plan_sheets")
}

model Takeoff {
  id            String        @id @default(uuid())
  project_id    String
  plan_set_id   String
  name          String
  description   String?
  status        TakeoffStatus @default(draft)
  created_by    String
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  plan_set      PlanSet       @relation(fields: [plan_set_id], references: [id])
  items         TakeoffItem[]

  @@index([project_id])
  @@index([plan_set_id])
  @@map("takeoffs")
}

model TakeoffItem {
  id                  String            @id @default(uuid())
  takeoff_id          String
  plan_sheet_id       String
  shape_type          ShapeType
  geometry            Json              // ShapeGeometry JSONB
  quantity            Decimal           @db.Decimal(12, 4)
  quantity_with_waste Decimal?          @db.Decimal(12, 4)
  unit                MeasurementUnit   @default(EA)
  csi_code            String
  csi_description     String
  label               String
  confidence          Float             @default(0.0)
  status              TakeoffItemStatus @default(ai_detected)
  reviewed_by         String?
  reviewed_at         DateTime?
  override_qty        Decimal?          @db.Decimal(12, 4)
  override_reason     String?
  ai_model_source     String?           // "claude" | "gpt4o" | "consensus"
  sort_order          Int               @default(0)
  created_by          String
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt

  takeoff             Takeoff           @relation(fields: [takeoff_id], references: [id], onDelete: Cascade)
  plan_sheet          PlanSheet         @relation(fields: [plan_sheet_id], references: [id])

  @@index([takeoff_id])
  @@index([plan_sheet_id])
  @@index([csi_code])
  @@index([status])
  @@map("takeoff_items")
}
